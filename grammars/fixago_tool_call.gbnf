# Fixago tool call grammar — constrains model output to either:
#   1. A CALL_TOOL directive (for tool dispatch)
#   2. A plain text response (Vietnamese assistant reply)
#
# Use with: cheese-server --grammar grammars/fixago_tool_call.gbnf
# NOTE: This is for legacy mode only. Native --jinja mode is preferred.

root ::= tool-call | text-response

# ── Tool call directives ────────────────────────────────────────────────────
tool-call ::= get-groups | get-services | get-promotions | create-booking

get-groups ::= "CALL_TOOL: get_groups()"

get-services ::= "CALL_TOOL: get_services(search=\"" service-key "\")"
service-key ::= "điện" | "nước" | "điện lạnh" | "xây dựng" | "thạch cao"

get-promotions ::= "CALL_TOOL: get_promotions()"

create-booking ::= "CALL_TOOL: create_booking(name=\"" safe-str "\", phone=\"" phone-str "\", address=\"" safe-str "\", description=\"" safe-str "\")"

# ── Primitives ──────────────────────────────────────────────────────────────
safe-str  ::= [^\"\n\r]{1,200}
phone-str ::= ("0" | "+84") [0-9]{8,10}

# ── Free-text response (Vietnamese, max ~500 chars) ─────────────────────────
text-response ::= [^\x00]{1,500}
