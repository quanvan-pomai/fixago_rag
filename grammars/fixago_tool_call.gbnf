root ::= tool-call | text-response

# ── Tool call directives ────────────────────────────────────────────────────
tool-call ::= get-groups | get-services | get-promotions | create-booking

get-groups ::= "CALL_TOOL: get_groups()"

get-services ::= "CALL_TOOL: get_services(search=\"" service-key "\")"
# Đã sửa thành "máy lạnh" để khớp với logic backend
service-key ::= "điện" | "nước" | "máy lạnh" | "xây dựng" | "thạch cao"

get-promotions ::= "CALL_TOOL: get_promotions()"

# Đã chèn thêm biến 'ws' để LLM thoải mái giãn cách các tham số
create-booking ::= "CALL_TOOL: create_booking(name=\"" safe-str "\"," ws "phone=\"" phone-str "\"," ws "address=\"" safe-str "\"," ws "description=\"" safe-str "\")"

# ── Primitives ──────────────────────────────────────────────────────────────
# Khoảng trắng tùy chọn (có hoặc không có đều được)
ws ::= [ \t]*

# Dùng dấu + thay vì {1,200} để giải phóng sức mạnh CPU
safe-str  ::= [^\"\n\r]+
phone-str ::= ("0" | "+84") [0-9]{8,10}

# ── Free-text response (Vietnamese) ─────────────────────────────────────────
# Dùng dấu + thay vì {1,500}, việc giới hạn chiều dài để max_tokens lo
text-response ::= [^\x00]+