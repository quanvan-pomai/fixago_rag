# Port on which the RAG Server runs
RAG_PORT=8081

# The URL of the NestJS Backend API
BACKEND_API_URL=http://127.0.0.1:3001/api/v1

# The URL of the Cheesebrain / vLLM API
LLM_API_URL=http://127.0.0.1:8080/v1/chat/completions

# Absolute path to the compiled PomaiDB C++ library (optional, auto-detected if omitted)
# POMAI_C_LIB=/path/to/pomaidb_core.so
